# DATABASE_URL: Supabase transaction pooler connection string (port 6543)
# Get from: Supabase Dashboard -> Settings -> Database -> Connection String (URI, Transaction mode)
DATABASE_URL="postgres://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require"

# APP_URL: Where the app is hosted (used for canonical URLs, sitemap)
APP_URL="https://bromance.blog"

# CMS Authentication
CMS_USERNAME=""
CMS_PASSWORD=""

# Cloudinary (media uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="bromance-blog"

# Cloudinary client-side (must match CLOUDINARY_CLOUD_NAME — needed for URL construction in browser)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Supabase Direct Connection (for backups — port 5432, NOT transaction pooler 6543)
# Get from: Supabase Dashboard -> Settings -> Database -> Connection String (URI, Direct)
# Only needed for backup/restore operations (pg_dump requires direct connection)
SUPABASE_DB_URL=""

# Analytics (optional)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_URL=""
